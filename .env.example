# Runtime profile. Use "production" only with explicit CORS origins and a real JWT secret.
NES_APP_ENV=development

# Comma-separated frontend origins allowed to call the FastAPI backend.
NES_CORS_ORIGINS=http://127.0.0.1:3060

# JWT signing secret for backend/app/auth.py. Replace this in every non-demo environment.
NES_JWT_SECRET=replace-with-a-long-random-secret

# Optional path to a JSON user registry consumed by backend/app/auth.py.
# When unset in development, the demo admin/guest accounts remain available.
NES_USERS_JSON=

# Optional Python logging level for backend API and task runner logs.
NES_LOG_LEVEL=INFO

# Optional MySQL application query database.
# Leave unset for local demo/review mode so the API reads CSV/JSON/Parquet files
# from data/processed/pvdaq_nsrdb_2020_2022. Set it only when the display data
# has already been imported into MySQL; missing imported rows intentionally
# surface as explicit 503 API errors.
# NES_DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/new_energy_sys?charset=utf8mb4
