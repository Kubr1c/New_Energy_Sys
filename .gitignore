.venv/
__pycache__/
*.py[cod]
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.env
.env.*
!.env.example
.local_secrets/

# Local assistant/tool scratch state.  These folders are recreated by Codex,
# Claude Code, or ad-hoc audit runs and should not be part of reproducible
# project evidence.
.claude/
.codex_tmp/
.tmp_*
tmp/
output/
Anewthesis/
更新-上海电力大学本科生毕业设计（论文）工作检查细则等17个文件/

# Raw public datasets can be large and should be reproducible from config.
data/raw/

# Processed artifacts are generated by CLI commands.
data/processed/

# Frontend dependencies, build outputs, and local test artifacts.
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/playwright-report/
frontend/test-results/

# Python package metadata generated by editable installs/builds.
*.egg-info/

# Large/local report attachments should be stored outside Git or in release assets.
reports/*.mp4
reports/*.webm
reports/*.doc
reports/*.docx
reports/*.pdf
reports/*.html

# Thesis build outputs and editor lock files. Keep source files such as
# thesis/main.tex visible, but hide generated render/export artifacts.
~$*
thesis/*.aux
thesis/*.log
thesis/*.out
thesis/*.toc
thesis/*.pdf
thesis/*.html
thesis/*.doc
thesis/*.docx
thesis/*.tmp.docx
thesis/draft_extracted.txt

# Git worktree isolation directory.
.worktrees/

# Local cloud credentials and SSH private keys must never enter version control.
*_accessKeys.csv
*accessKeys*.csv
*.pem
